    "repository": "https://github.com/99x/xianix-team",
    "license": "MIT",
    "keywords": [
      "performance",
      "performance-optimization",
      "performance-review",
      "pull-request",
      "latency",
      "cpu",
      "memory",
      "n-plus-one",
      "azure-devops",
      "github"
    ],
    "commands": ["./commands/perf-optimize.md"],
    "agents": [
      "./agents/orchestrator.md",
      "./agents/latency-analyzer.md",
      "./agents/cpu-analyzer.md",
      "./agents/memory-analyzer.md",
      "./agents/io-query-analyzer.md",
      "./agents/fix-pr-author.md"
    ],
    "skills": "./skills/",
    "hooks": "./hooks/hooks.json",
    "outputStyles": "./styles/",
    "providers": "./providers/",
    "lspServers": "./.claude-plugin/.lsp.json"
