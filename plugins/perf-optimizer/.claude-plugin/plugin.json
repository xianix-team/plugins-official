{
    "name": "perf-optimizer",
    "version": "2.0.0",
    "description": "Whole-codebase performance bottleneck detection triggered from a GitHub issue or Azure DevOps work item, delivered as a ready-to-review fix PR. Detects latency, CPU, memory, and I/O / query inefficiencies across the repository's default branch. Works with GitHub and Azure DevOps.",
    "author": {
      "name": "99x",
      "email": "xianix@99x.io",
      "url": "https://github.com/99x"
    },
    "homepage": "https://github.com/99x/xianix-team",
    "repository": "https://github.com/99x/xianix-team",
    "license": "MIT",
    "keywords": [
      "performance",
      "performance-optimization",
      "performance-review",
      "issue-driven",
      "whole-codebase",
      "latency",
      "cpu",
      "memory",
      "n-plus-one",
      "azure-devops",
      "github"
    ],
    "commands": ["./commands/perf-optimize.md"],
    "agents": [
      "./agents/orchestrator.md",
      "./agents/latency-analyzer.md",
      "./agents/cpu-analyzer.md",
      "./agents/memory-analyzer.md",
      "./agents/io-query-analyzer.md",
      "./agents/perf-pr-author.md"
    ],
    "skills": "./skills/",
    "hooks": "./hooks/hooks.json",
    "outputStyles": "./styles/",
    "providers": "./providers/",
    "lspServers": "./.claude-plugin/.lsp.json"
  }
